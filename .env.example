# ============================================================
# WORKSHOP: Claude Code + APIs de Marketing
# ============================================================
# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env
#
# IMPORTANTE: O arquivo .env NUNCA deve ser commitado no Git.
# Ele ja esta no .gitignore para sua seguranca.
# ============================================================


# --- META MARKETING API ---
# Como obter: guias/02-meta-ads-api.md
# Token de ~60 dias (precisa renovar periodicamente)
META_ACCESS_TOKEN="cole_seu_token_aqui"

# ID da conta de anuncios (formato: act_XXXXXXXXX)
# Encontre em: Business Manager > Ad Accounts
META_AD_ACCOUNT_ID="act_XXXXXXXXX"

# Credenciais do app (developers.facebook.com > Your Apps)
META_APP_ID="seu_app_id"
META_APP_SECRET="seu_app_secret"


# --- GOOGLE ADS API ---
# Como obter: guias/03-google-ads-api.md
# Developer Token: ads.google.com > Tools > API Center
GOOGLE_ADS_DEVELOPER_TOKEN="seu_developer_token"

# MCC (conta gerenciadora) - formato XXX-XXX-XXXX
GOOGLE_ADS_MCC_CUSTOMER_ID="XXX-XXX-XXXX"

# OAuth2 (console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_ADS_CLIENT_ID="seu_client_id.apps.googleusercontent.com"
GOOGLE_ADS_CLIENT_SECRET="GOCSPX-seu_client_secret"
GOOGLE_ADS_REFRESH_TOKEN="seu_refresh_token"

# ID da conta Google Ads que voce quer consultar (sem hifens)
GOOGLE_ADS_CUSTOMER_ID="XXXXXXXXXX"


# --- GOOGLE SERVICES (Service Account) ---
# Como obter: guias/04-ga4-api.md e guias/09-autenticacao-google.md
# Service Account: configura 1 vez, nunca expira!
# Arquivo JSON unico usado por GA4, Google Sheets e demais servicos Google
# (fica na raiz do projeto, no .gitignore)
GOOGLE_SERVICE_ACCOUNT_JSON="google-services.json"

# Property ID do GA4 (Admin > Property Settings)
GA4_PROPERTY_ID="XXXXXXXXX"

# --- GOOGLE SHEETS ---
# ID da planilha (trecho da URL entre /d/ e /edit)
GOOGLE_SHEETS_SPREADSHEET_ID="cole_o_id_da_planilha_aqui"


# --- NOTION API (OPCIONAL) ---
# Como obter: guias/10-notion-api.md
# Integration token: notion.so/my-integrations
NOTION_TOKEN="cole_seu_token_aqui"


# --- WINDSOR AI (OPCIONAL) ---
# Como obter: guias/05-windsor-mcp.md
# So precisa se for usar o Windsor MCP
# WINDSOR_API_KEY="sua_api_key"
